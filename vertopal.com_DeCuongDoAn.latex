\section*{1. Tên đề tài}
\textbf{Xây dựng hệ thống AI tối ưu hóa lịch trình tàu điện ngầm MTA New York dựa trên dự báo nhu cầu hành khách và điều kiện vận hành.}

\section*{2. Mục đích, yêu cầu}

\subsection*{2.1. Mục đích}
\begin{itemize}
  \item Nghiên cứu và xây dựng pipeline end-to-end từ dữ liệu thực (ridership theo giờ, lịch GTFS, yếu tố thời tiết--lịch) đến lịch trình tối ưu theo từng tuyến $\times$ hướng $\times$ giờ.
  \item Phát triển mô hình học sâu (TensorFlow/Keras) dự báo nhu cầu hành khách, kết hợp baseline theo lịch sử và feature thời tiết/lịch (\texttt{factors\_hourly}).
  \item Tối ưu số chuyến/headway bằng phương pháp analytical per-slot, có chính sách auto-chọn trọng số $\lambda$ theo mục tiêu (\texttt{wait}, \texttt{cost}, \texttt{objective}, \texttt{balanced}).
  \item Đánh giá trên các kịch bản vận hành: giờ cao điểm ngày thường, cuối tuần, ngày mưa; kiểm thử suy luận lịch trình cho mẫu thời tiết năm 2026 (Open-Meteo).
  \item So sánh hiệu quả giữa lịch baseline (GTFS hiện hành) và lịch tối ưu theo các chỉ số passenger-min chờ, chi phí đội xe, objective tổng hợp.
\end{itemize}

\subsection*{2.2. Yêu cầu}
\begin{itemize}
  \item Hợp nhất và làm sạch dữ liệu MTA: \texttt{ridership.csv}, \texttt{routes\_by\_station\_complex.csv}, \texttt{factors\_hourly.csv}, \texttt{schedule\_current/} (GTFS).
  \item Huấn luyện mô hình dự báo demand với validation theo ngày (train/val/test), báo cáo MAE, $R^2$, MAPE; so sánh với baseline median theo route--hour--weekend.
  \item Xây dựng hàm mục tiêu: $\text{objective} = \text{passenger-min wait} + \lambda \times \text{total trips}$.
  \item Triển khai tối ưu analytical: $t^\ast = \sqrt{30D/\lambda}$ (clip theo ràng buộc tuyến), quét \texttt{LAMBDA\_CANDIDATES} khi dùng policy \texttt{balanced}.
  \item Xuất artifact: \texttt{results\_summary.csv}, \texttt{tradeoff\_summary.csv}, \texttt{schedule\_weekday\_peak.csv}, \texttt{baseline\_metrics.json}, biểu đồ EDA/trade-off/lambda sensitivity.
  \item Pipeline phải xử lý an toàn giá trị thiếu (fallback baseline nhiều tầng, \texttt{nan\_to\_num}) để metric không bị NaN.
\end{itemize}

\section*{3. Nội dung và phạm vi đề tài}

\subsection*{3.1. Nội dung chi tiết theo pipeline hiện tại}

\textbf{Bước 1 — Thu thập và hợp nhất dữ liệu}
\begin{itemize}
  \item Đọc ridership theo chunk; map station complex $\rightarrow$ route qua \texttt{routes\_by\_station\_complex.csv}.
  \item Join \texttt{factors\_hourly} theo khóa \texttt{(date, hour)}: nhiệt độ, mưa, gió, cờ peak/overnight/holiday.
  \item Dựng baseline headway/trip count từ GTFS (\texttt{trips.txt}, \texttt{stop\_times.txt}, \texttt{calendar.txt}); fallback median khi thiếu slot.
\end{itemize}

\textbf{Bước 2 — Khám phá và chọn phạm vi tối ưu}
\begin{itemize}
  \item Chọn tuyến theo mode \texttt{headway} (29 tuyến trong bản chạy đầy đủ).
  \item Scope: $29 \times 2 \times 24 = 1{,}392$ slots (route, direction, hour).
  \item EDA: heatmap demand theo giờ, weekday vs weekend, clear vs rainy.
\end{itemize}

\textbf{Bước 3 — Mô hình dự báo demand (Neural Network)}
\begin{itemize}
  \item Kiến trúc: embedding \texttt{route\_idx} + dense numeric features + residual trên \texttt{log\_baseline}.
  \item Feature: sin/cos giờ, ngày trong tuần, \texttt{is\_weekend}, \texttt{is\_us\_holiday}, các cột thời tiết từ \texttt{factors\_hourly}, \texttt{log\_baseline}.
  \item Target: residual $\log(1+\text{demand}) - \log(1+\text{baseline\_demand})$; clip residual $\pm 0.4$.
  \item Đánh giá: holdout + K-fold CV (5 folds); EarlyStopping trên val loss.
\end{itemize}

\textbf{Bước 4 — Mô hình hóa chờ và mục tiêu}
\begin{itemize}
  \item Headway trung bình: $h = 60/t$ (phút), $t$ = số chuyến/giờ/slot.
  \item Thời gian chờ trung bình hành khách: $w = h/2$.
  \item Passenger-min wait: $\sum_i D_i \cdot w_i$; fleet cost: $\lambda \sum_i t_i$.
\end{itemize}

\textbf{Bước 5 — Tối ưu lịch trình}
\begin{itemize}
  \item Phương pháp chính: \textbf{Analytical per-slot} (nhanh, deterministic).
  \item Tùy chọn nghiên cứu: Genetic Algorithm + Tabu Search khi \texttt{USE\_ANALYTICAL\_OPT=False} và số slot nhỏ.
  \item Policy \texttt{OPT\_TARGET=balanced}: chấm điểm $\alpha \cdot \text{wait\_ratio} + \beta \cdot \text{cost\_ratio}$ ($\alpha=0.6$, $\beta=0.4$).
\end{itemize}

\textbf{Bước 6 — Đánh giá kịch bản}
\begin{itemize}
  \item \texttt{weekday\_peak}: ngày thường, không mưa.
  \item \texttt{weekend}: cuối tuần.
  \item \texttt{rainy\_day}: ngày mưa ($\texttt{rain\_mm}=12$, $\texttt{is\_rain}=1$).
  \item Phân tích độ nhạy $\lambda \in \{100, 150, 200\}$ trên \texttt{weekday\_peak}.
\end{itemize}

\textbf{Bước 7 — Suy luận mẫu 2026}
\begin{itemize}
  \item Crawl/thu thập \texttt{factors\_hourly\_2026\_samples.csv} (Open-Meteo, NYC).
  \item Với từng ngày mẫu: suy demand $\rightarrow$ chọn $\lambda\_opt$ $\rightarrow$ xuất lịch \texttt{opt\_trips}.
\end{itemize}

\subsection*{3.2. Phạm vi đề tài}
\begin{itemize}
  \item Hệ thống tàu điện ngầm MTA NYC; dữ liệu ridership và GTFS trong bundle hiện có.
  \item Tối ưu ở mức macro: trips/headway theo slot (route $\times$ direction $\times$ hour), chưa mô phỏng vi mô từng đoàn tàu/độ dài tàu.
  \item Metric chi phí là mô hình hóa ($\lambda \times$ trips), chưa tích hợp chi phí nhiên liệu/nhân sự thực tế.
  \item Phục vụ mục đích học thuật và demo khoa học dữ liệu; chưa triển khai vận hành trực tiếp với MTA.
\end{itemize}

\section*{4. Công nghệ, công cụ và ngôn ngữ lập trình}
\begin{itemize}
  \item \textbf{Ngôn ngữ:} Python 3.
  \item \textbf{Môi trường:} Jupyter Notebook, Visual Studio Code / Cursor.
  \item \textbf{Thư viện:} pandas, NumPy, scikit-learn, TensorFlow/Keras, Matplotlib, Seaborn.
  \item \textbf{Dữ liệu:} CSV, GTFS (\texttt{.txt}), JSON manifest; API Open-Meteo (archive) cho mẫu 2026.
  \item \textbf{Quản lý mã nguồn:} Git, GitHub (đề xuất tên repo: \texttt{mta-demand-aware-schedule-optimizer}).
  \item \textbf{Tài liệu:} \LaTeX{} (đề cương, báo cáo), notebook reproducible.
\end{itemize}

\section*{5. Kết quả chính đã đạt được (bản chạy đầy đủ 29 tuyến)}

\subsection*{5.1. Chất lượng mô hình dự báo}
\begin{center}
\begin{tabular}{lccc}
\toprule
Chỉ số & Baseline & Neural Network & Cải thiện \\
\midrule
Holdout MAE & 932 & 643 & $-31.0\%$ \\
Holdout $R^2$ & 0.886 & 0.946 & --- \\
CV MAE (5 folds) & $760 \pm 42$ & $587 \pm 47$ & $-22.8\%$ \\
\bottomrule
\end{tabular}
\end{center}

\subsection*{5.2. Tối ưu lịch trình ($\lambda=150$, Analytical)}
\begin{center}
\begin{tabular}{lcccc}
\toprule
Kịch bản & Wait TB (phút) & Objective & Giảm objective & Trips \\
\midrule
weekday\_peak & $4.39 \rightarrow 2.32$ & $42.7\text{M} \rightarrow 24.2\text{M}$ & $-43.3\%$ & $9{,}718 \rightarrow 16{,}135$ \\
weekend       & $4.70 \rightarrow 2.41$ & $30.4\text{M} \rightarrow 17.3\text{M}$ & $-43.2\%$ & $9{,}718 \rightarrow 16{,}078$ \\
rainy\_day    & $4.38 \rightarrow 2.32$ & $35.7\text{M} \rightarrow 20.5\text{M}$ & $-42.5\%$ & $9{,}718 \rightarrow 15{,}967$ \\
\bottomrule
\end{tabular}
\end{center}
\noindent
Headway ổn định hơn: $\sigma_h$ giảm từ $\approx 7.47$ xuống $\approx 4.5$--$4.8$. Passenger-min chờ giảm khoảng \textbf{47\%}; fleet cost tăng $\approx 940k$--$963k$ do số chuyến tăng $\approx 66\%$.

\subsection*{5.3. Độ nhạy $\lambda$ (weekday\_peak)}
\begin{itemize}
  \item $\lambda=100$: objective thấp nhất ($\approx 23.4$M), improvement $\approx 44.6\%$.
  \item $\lambda=150$: cân bằng (đang dùng mặc định), improvement $\approx 43.3\%$.
  \item $\lambda=200$: ít chuyến hơn, fleet cost cao hơn, improvement $\approx 42.1\%$.
\end{itemize}

\subsection*{5.4. Mẫu thử 2026 (3 ngày, policy balanced)}
\begin{center}
\begin{tabular}{lcc}
\toprule
Ngày & Giảm objective & Giảm wait \\
\midrule
2026-01-15 & $42.8\%$ & $47.1\%$ \\
2026-03-28 & $42.0\%$ & $48.4\%$ \\
2026-05-12 & $43.3\%$ & $47.0\%$ \\
\bottomrule
\end{tabular}
\end{center}

\subsection*{5.5. Sản phẩm phần mềm dự kiến hoàn thiện}
\begin{itemize}
  \item Notebook \texttt{mta\_schedule\_optimization.ipynb} (pipeline đầy đủ).
  \item Notebook \texttt{mta\_schedule\_optimization\_single\_route.ipynb} (ablation 1 tuyến).
  \item Bộ file kết quả trong \texttt{notebooks/outputs/}: CSV, JSON, biểu đồ PNG.
  \item Báo cáo TKTN: mô tả dữ liệu, mô hình, thuật toán, thí nghiệm, hạn chế và hướng phát triển.
\end{itemize}

\section*{6. Kế hoạch triển khai báo cáo (gợi ý)}
\begin{enumerate}
  \item Chương 1--2: Cơ sở lý thuyết (quy hoạch vận tải, headway, GA/Tabu, học sâu dự báo series).
  \item Chương 3: Phân tích dữ liệu MTA và tiền xử lý.
  \item Chương 4: Mô hình dự báo demand và đánh giá.
  \item Chương 5: Mô hình hóa mục tiêu và tối ưu lịch trình.
  \item Chương 6: Thí nghiệm, so sánh baseline--optimized, độ nhạy $\lambda$, mẫu 2026.
  \item Chương 7: Kết luận và hướng phát triển (cap trips thực tế, multi-objective Pareto, tích hợp realtime API).
\end{enumerate}

